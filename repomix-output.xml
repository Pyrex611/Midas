import prisma from '../lib/prisma';
import { encrypt, decrypt } from '../lib/encryption';
import { logger } from '../config/logger';

export class MailboxService {
  /**
   * Create a new mailbox for a user.
   */
  async createMailbox(
    userId: string,
    data: {
      name: string;
      email: string;
      senderName?: string;
      smtpHost?: string;
      smtpPort?: number;
      smtpSecure?: boolean;
      smtpUser?: string;
      smtpPass?: string;
      imapHost?: string;
      imapPort?: number;
      imapSecure?: boolean;
      imapUser?: string;
      imapPass?: string;
      sendLimit?: number;
      sendPeriod?: string;
      isPrimary?: boolean;
    }
  ) {
    const { smtpPass, imapPass, ...rest } = data;

    const encryptedData: any = { ...rest };
    if (smtpPass) encryptedData.smtpPass = encrypt(smtpPass);
    if (imapPass) encryptedData.imapPass = encrypt(imapPass);

    // If setting as primary, unset any existing primary for this user
    if (data.isPrimary) {
      await prisma.mailbox.updateMany({
        where: { userId, isPrimary: true },
        data: { isPrimary: false },
      });
    }

    const mailbox = await prisma.mailbox.create({
      data: {
        userId,
        ...encryptedData,
      },
    });

    logger.info({ mailboxId: mailbox.id, userId }, 'Mailbox created');
    return mailbox;
  }

  /**
   * Get all mailboxes for a user, decrypting passwords? (We don't decrypt for security)
   * Instead, return only metadata, and a flag if password is set.
   */
  async getUserMailboxes(userId: string) {
    const mailboxes = await prisma.mailbox.findMany({
      where: { userId, isActive: true },
      orderBy: { createdAt: 'desc' },
    });
    // Remove encrypted fields, add a flag indicating password presence
    return mailboxes.map(m => ({
      ...m,
      smtpPass: m.smtpPass ? '********' : null,
      imapPass: m.imapPass ? '********' : null,
    }));
  }

  /**
   * Get a mailbox by ID (for sending, includes decrypted passwords).
   * Only call this from trusted services (email sending).
   */
  async getMailboxForSending(id: string) {
    const mailbox = await prisma.mailbox.findUnique({ where: { id } });
    if (!mailbox) throw new Error('Mailbox not found');
    // Decrypt passwords
    return {
      ...mailbox,
      smtpPass: mailbox.smtpPass ? decrypt(mailbox.smtpPass) : null,
      imapPass: mailbox.imapPass ? decrypt(mailbox.imapPass) : null,
    };
  }

  /**
   * Update a mailbox.
   */
  async updateMailbox(
    userId: string,
    id: string,
    data: Partial<{
      name: string;
      email: string;
      senderName: string;
      smtpHost: string;
      smtpPort: number;
      smtpSecure: boolean;
      smtpUser: string;
      smtpPass: string;
      imapHost: string;
      imapPort: number;
      imapSecure: boolean;
      imapUser: string;
      imapPass: string;
      sendLimit: number;
      sendPeriod: string;
      isActive: boolean;
      isPrimary: boolean;
    }>
  ) {
    // Ensure mailbox belongs to user
    const existing = await prisma.mailbox.findFirst({ where: { id, userId } });
    if (!existing) throw new Error('Mailbox not found or not owned by user');

    const { smtpPass, imapPass, ...rest } = data;
    const encryptedData: any = { ...rest };
    if (smtpPass) encryptedData.smtpPass = encrypt(smtpPass);
    if (imapPass) encryptedData.imapPass = encrypt(imapPass);

    if (data.isPrimary) {
      await prisma.mailbox.updateMany({
        where: { userId, isPrimary: true, NOT: { id } },
        data: { isPrimary: false },
      });
    }

    const updated = await prisma.mailbox.update({
      where: { id },
      data: encryptedData,
    });

    logger.info({ mailboxId: id, userId }, 'Mailbox updated');
    return updated;
  }

  /**
   * Delete a mailbox (soft delete by setting isActive false).
   */
  async deleteMailbox(userId: string, id: string) {
    const existing = await prisma.mailbox.findFirst({ where: { id, userId } });
    if (!existing) throw new Error('Mailbox not found');
    await prisma.mailbox.update({
      where: { id },
      data: { isActive: false, isPrimary: false },
    });
    logger.info({ mailboxId: id, userId }, 'Mailbox deactivated');
  }

  /**
   * Select a mailbox from a campaign's pool for sending an email.
   * If preferredMailboxId is provided and still in pool and has quota, use it.
   * Otherwise, round‑robin.
   */
  async selectMailboxForCampaign(
    campaignId: string,
    preferredMailboxId?: string | null
  ): Promise<{ mailbox: any; index: number } | null> {
    // Get campaign with its mailbox links and current index
    const campaign = await prisma.campaign.findUnique({
      where: { id: campaignId },
      include: {
        mailboxLinks: {
          include: { mailbox: true },
        },
      },
    });
    if (!campaign) throw new Error('Campaign not found');
    if (campaign.mailboxLinks.length === 0) return null;

    const mailboxes = campaign.mailboxLinks.map(link => link.mailbox);

    // If preferred is provided, try it first
    if (preferredMailboxId) {
      const preferred = mailboxes.find(m => m.id === preferredMailboxId);
      if (preferred) {
        // Check if it has quota (we'll check in queue, but here we can also do a basic check)
        // For now, we'll just return it; the queue will enforce limits.
        return { mailbox: preferred, index: -1 };
      }
    }

    // Round‑robin
    const index = campaign.lastMailboxIndex % mailboxes.length;
    const selected = mailboxes[index];
    // Update the index for next time (increment modulo)
    await prisma.campaign.update({
      where: { id: campaignId },
      data: { lastMailboxIndex: (index + 1) % mailboxes.length },
    });
    return { mailbox: selected, index };
  }
}

export const mailboxService = new MailboxService();
