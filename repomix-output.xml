generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String    @unique
  name          String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  leads         Lead[]
  campaigns     Campaign[]
  drafts        Draft[]
  settings      UserSettings?
  mailboxes     Mailbox[]

  // For backward compatibility (will be deprecated later)
  outboundEmails OutboundEmail[]
  pendingEmails  PendingEmail[]

  @@map("User")
}

model Mailbox {
  id         String   @id @default(cuid())
  userId     String   @map("user_id") @db.Uuid
  user       User     @relation(fields: [userId], references: [id])
  name       String
  email      String
  senderName String?  @map("sender_name")

  // SMTP settings (encrypted)
  smtpHost   String?
  smtpPort   Int?
  smtpSecure Boolean?
  smtpUser   String?
  smtpPass   String?  // encrypted

  // IMAP settings (optional)
  imapHost   String?
  imapPort   Int?
  imapSecure Boolean?
  imapUser   String?
  imapPass   String?  // encrypted

  // OAuth fields (future)
  provider     String? // 'gmail', 'outlook'
  refreshToken String? @map("refresh_token") // encrypted
  accessToken  String? @map("access_token")  // encrypted

  // Send limits
  sendLimit     Int      @default(50)
  sendPeriod    String   @default("day")
  sentCount     Int      @default(0)
  lastSentReset DateTime @default(now()) @map("last_sent_reset")
  lastSend      DateTime? @map("last_send")

  // Status
  isActive    Boolean @default(true)
  isPrimary   Boolean @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  campaigns     CampaignMailbox[]
  outboundEmails OutboundEmail[] @relation("OutboundEmailMailbox")

  // Two distinct relations to PendingEmail
  pendingEmails        PendingEmail[] @relation("PendingEmailMailbox")
  preferredPendingEmails PendingEmail[] @relation("PendingEmailPreferred")

  @@index([userId])
  @@index([email])
  @@map("Mailbox")
}

model CampaignMailbox {
  id         String   @id @default(cuid())
  campaignId String   @map("campaign_id")
  campaign   Campaign @relation(fields: [campaignId], references: [id])
  mailboxId  String   @map("mailbox_id")
  mailbox    Mailbox  @relation(fields: [mailboxId], references: [id])
  addedAt    DateTime @default(now()) @map("added_at")

  @@unique([campaignId, mailboxId])
  @@map("CampaignMailbox")
}

model Campaign {
  id          String   @id @default(cuid())
  userId      String   @map("user_id") @db.Uuid
  user        User     @relation(fields: [userId], references: [id])
  name        String
  description String?
  context     String?
  reference   String?
  senderName  String?  @map("sender_name")
  status      String   @default("DRAFT")
  createdAt   DateTime @default(now()) @map("created_at")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")

  // NEW: round‑robin index for mailbox selection
  lastMailboxIndex Int @default(0) @map("last_mailbox_index")

  followUpSteps FollowUpStep[]
  autoReplyEnabled Boolean @default(false) @map("auto_reply_enabled")
  sendHourUTC Int      @default(9) @map("send_hour_utc")
  activeStartHour Int?     @map("active_start_hour")
  activeEndHour   Int?     @map("active_end_hour")
  timezone        String?

  leads  Lead[]
  emails OutboundEmail[]
  drafts Draft[]
  pendingEmails PendingEmail[]
  mailboxLinks CampaignMailbox[] // many-to-many

  @@index([userId])
  @@index([status])
  @@map("Campaign")
}

model Lead {
  id        String   @id @default(cuid())
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  name      String
  email     String
  company   String?
  position  String?
  status    String   @default("NEW")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  outreachStatus String?  @map("outreach_status")
  campaignId     String?  @map("campaign_id")
  campaign       Campaign? @relation(fields: [campaignId], references: [id])
  sentEmails     OutboundEmail[]
  replyDrafts    Draft[]         @relation("LeadDrafts")
  pendingEmails  PendingEmail[]

  @@unique([userId, email])
  @@index([status])
  @@index([campaignId])
  @@index([userId])
  @@map("Lead")
}

model Draft {
  id        String   @id @default(cuid())
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  subject   String
  body      String
  tone      String
  useCase   String   @map("use_case")
  version   Int      @default(1)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  campaignId String?  @map("campaign_id")
  campaign   Campaign? @relation(fields: [campaignId], references: [id])

  leadId       String?  @map("lead_id")
  lead         Lead?    @relation("LeadDrafts", fields: [leadId], references: [id])
  isReplyDraft Boolean  @default(false) @map("is_reply_draft")
  stepNumber   Int?     @map("step_number") // for follow‑up drafts

  sentCount  Int @default(0) @map("sent_count")
  replyCount Int @default(0) @map("reply_count")

  emails OutboundEmail[]
  followUpSteps FollowUpStep[]
  pendingEmails PendingEmail[]

  @@index([isActive])
  @@index([tone, useCase])
  @@index([campaignId])
  @@index([leadId])
  @@index([userId])
  @@index([stepNumber])
  @@map("Draft")
}

model FollowUpStep {
  id         String   @id @default(cuid())
  campaignId String   @map("campaign_id")
  campaign   Campaign @relation(fields: [campaignId], references: [id])
  stepNumber Int
  delayDays  Int
  draftId    String?  @map("draft_id")
  draft      Draft?   @relation(fields: [draftId], references: [id])
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([campaignId, stepNumber])
  @@map("FollowUpStep")
}

model OutboundEmail {
  id         String   @id @default(cuid())
  // 🔵 KEPT: old userId field
  userId     String   @map("user_id") @db.Uuid
  user       User     @relation(fields: [userId], references: [id])

  // 🟢 NEW: optional mailbox link with named relation
  mailboxId  String?  @map("mailbox_id")
  mailbox    Mailbox? @relation("OutboundEmailMailbox", fields: [mailboxId], references: [id])

  leadId     String   @map("lead_id")
  lead       Lead     @relation(fields: [leadId], references: [id])
  campaignId String?  @map("campaign_id")
  campaign   Campaign? @relation(fields: [campaignId], references: [id])
  draftId    String?  @map("draft_id")
  draft      Draft?   @relation(fields: [draftId], references: [id])
  
  subject    String
  body       String
  sentAt     DateTime @default(now()) @map("sent_at")
  status     String   @default("SENT")
  error      String?

  openedAt  DateTime? @map("opened_at")
  repliedAt DateTime? @map("replied_at")
  replyText String?   @map("reply_text")

  replyToId   String?       @map("reply_to_id")
  replyTo     OutboundEmail? @relation("Replies", fields: [replyToId], references: [id])
  replies     OutboundEmail[] @relation("Replies")
  isIncoming  Boolean        @default(false) @map("is_incoming")
  messageId   String?        @map("message_id")
  references  String?
  inReplyTo   String?        @map("in_reply_to")
  fromAddress String?        @map("from_address")
  toAddress   String?        @map("to_address")

  sentiment   String?
  intent      String?
  analysis    String?

  @@index([leadId])
  @@index([campaignId])
  @@index([sentAt])
  @@index([messageId])
  @@index([userId])    // keep old
  @@index([mailboxId]) // new
  @@map("OutboundEmail")
}

model PendingEmail {
  id         String   @id @default(cuid())
  // 🔵 KEPT: old userId field
  userId     String   @map("user_id") @db.Uuid
  user       User     @relation(fields: [userId], references: [id])

  // 🟢 NEW: assigned mailbox (actual sending mailbox)
  mailboxId  String?  @map("mailbox_id")
  mailbox    Mailbox? @relation("PendingEmailMailbox", fields: [mailboxId], references: [id])

  campaignId String   @map("campaign_id")
  campaign   Campaign @relation(fields: [campaignId], references: [id])
  leadId     String   @map("lead_id")
  lead       Lead     @relation(fields: [leadId], references: [id])
  draftId    String?  @map("draft_id")
  draft      Draft?   @relation(fields: [draftId], references: [id])

  subject    String
  body       String
  inReplyTo  String?  @map("in_reply_to")
  scheduledAt DateTime? @map("scheduled_at")
  status     String   @default("PENDING")
  error      String?
  createdAt  DateTime @default(now()) @map("created_at")
  priority   Int      @default(2)

  // 🟢 NEW: preferred mailbox (for follow‑ups)
  preferredMailboxId String? @map("preferred_mailbox_id")
  preferredMailbox   Mailbox? @relation("PendingEmailPreferred", fields: [preferredMailboxId], references: [id])

  @@index([campaignId, status])
  @@index([scheduledAt])
  @@index([userId])        // keep old
  @@index([mailboxId])     // new
  @@index([preferredMailboxId])
  @@map("PendingEmail")
}

model UserSettings {
  userId        String   @id @map("user_id") @db.Uuid
  user          User     @relation(fields: [userId], references: [id])
  emailFrom     String?  @map("email_from")
  smtpHost      String?  @map("smtp_host")
  smtpPort      Int?     @map("smtp_port")
  smtpSecure    Boolean? @map("smtp_secure")
  smtpUser      String?  @map("smtp_user")
  smtpPass      String?  @map("smtp_pass")
  imapHost      String?  @map("imap_host")
  imapPort      Int?     @map("imap_port")
  imapSecure    Boolean? @map("imap_secure")
  imapUser      String?  @map("imap_user")
  imapPass      String?  @map("imap_pass")

  // Send limit settings
  sendLimit     Int      @default(50)
  sendPeriod    String   @default("day")
  sentCount     Int      @default(0)
  lastSentReset DateTime @default(now()) @map("last_sent_reset")
  lastSend      DateTime? @map("last_send")

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("UserSettings")
}
