generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email          String          @unique
  name           String?
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  leads          Lead[]
  campaigns      Campaign[]
  drafts         Draft[]
  outboundEmails OutboundEmail[]
  settings       UserSettings?

  @@map("User")
}

model Lead {
  id        String   @id @default(cuid())
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  name      String
  email     String
  company   String?
  position  String?
  status    String   @default("NEW")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  outreachStatus String?         @map("outreach_status")
  campaignId     String?         @map("campaign_id")
  campaign       Campaign?       @relation(fields: [campaignId], references: [id])
  sentEmails     OutboundEmail[]
  replyDrafts    Draft[]         @relation("LeadDrafts")

  @@unique([userId, email])
  @@index([status])
  @@index([campaignId])
  @@index([userId])
}

model Campaign {
  id          String    @id @default(cuid())
  userId      String    @map("user_id") @db.Uuid
  user        User      @relation(fields: [userId], references: [id])
  name        String
  description String?
  context     String?
  reference   String?
  senderName  String?   @map("sender_name")
  status      String    @default("DRAFT")
  createdAt   DateTime  @default(now()) @map("created_at")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")

  followUpEnabled  Boolean @default(false) @map("follow_up_enabled")
  followUpDelay    Int     @default(24) @map("follow_up_delay")
  autoReplyEnabled Boolean @default(false) @map("auto_reply_enabled")

  leads  Lead[]
  emails OutboundEmail[]
  drafts Draft[]

  @@index([userId])
  @@index([status])
}

model Draft {
  id        String   @id @default(cuid())
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  subject   String
  body      String
  tone      String
  useCase   String   @map("use_case")
  version   Int      @default(1)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  campaignId String?   @map("campaign_id")
  campaign   Campaign? @relation(fields: [campaignId], references: [id])

  leadId       String? @map("lead_id")
  lead         Lead?   @relation("LeadDrafts", fields: [leadId], references: [id])
  isReplyDraft Boolean @default(false) @map("is_reply_draft")

  sentCount  Int @default(0) @map("sent_count")
  replyCount Int @default(0) @map("reply_count")

  emails OutboundEmail[]

  @@index([isActive])
  @@index([tone, useCase])
  @@index([campaignId])
  @@index([leadId])
  @@index([userId])
}

model OutboundEmail {
  id         String    @id @default(cuid())
  userId     String    @map("user_id") @db.Uuid
  user       User      @relation(fields: [userId], references: [id])
  leadId     String    @map("lead_id")
  lead       Lead      @relation(fields: [leadId], references: [id])
  campaignId String?   @map("campaign_id")
  campaign   Campaign? @relation(fields: [campaignId], references: [id])
  draftId    String?   @map("draft_id")
  draft      Draft?    @relation(fields: [draftId], references: [id])

  subject String
  body    String
  sentAt  DateTime @default(now()) @map("sent_at")
  status  String   @default("SENT")
  error   String?

  openedAt  DateTime? @map("opened_at")
  repliedAt DateTime? @map("replied_at")
  replyText String?   @map("reply_text")

  replyToId   String?         @map("reply_to_id")
  replyTo     OutboundEmail?  @relation("Replies", fields: [replyToId], references: [id])
  replies     OutboundEmail[] @relation("Replies")
  isIncoming  Boolean         @default(false) @map("is_incoming")
  messageId   String?         @map("message_id")
  references  String?
  inReplyTo   String?         @map("in_reply_to")
  fromAddress String?         @map("from_address")
  toAddress   String?         @map("to_address")

  sentiment String?
  intent    String?
  analysis  String?

  @@index([leadId])
  @@index([campaignId])
  @@index([sentAt])
  @@index([messageId])
  @@index([userId])
}

model UserSettings {
  userId     String   @id @map("user_id") @db.Uuid // 👈 added @db.Uuid
  user       User     @relation(fields: [userId], references: [id])
  emailFrom  String?  @map("email_from")
  smtpHost   String?  @map("smtp_host")
  smtpPort   Int?     @map("smtp_port")
  smtpSecure Boolean? @map("smtp_secure")
  smtpUser   String?  @map("smtp_user")
  smtpPass   String?  @map("smtp_pass")
  imapHost   String?  @map("imap_host")
  imapPort   Int?     @map("imap_port")
  imapSecure Boolean? @map("imap_secure")
  imapUser   String?  @map("imap_user")
  imapPass   String?  @map("imap_pass")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("UserSettings")
}
